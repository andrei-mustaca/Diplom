@{
    ViewData["Title"] = "Панель рабочего";
}

<div class="dashboard-page">
    <div class="dashboard-header">
        <h1>🔧 Панель рабочего</h1>
        <p class="welcome-text">Добро пожаловать, @ViewBag.UserName!</p>
    </div>

    <div class="dashboard-grid">
        <div class="dashboard-card">
            <div class="card-icon">📋</div>
            <h3>Мои задачи</h3>
            <p>Просмотр назначенных задач и заявок</p>
        </div>
        <div class="dashboard-card">
            <div class="card-icon">✅</div>
            <h3>Выполненные работы</h3>
            <p>История выполненных задач</p>
        </div>
        <div class="dashboard-card">
            <div class="card-icon">📅</div>
            <h3>График</h3>
            <p>Расписание и планирование работ</p>
        </div>
    </div>
</div>