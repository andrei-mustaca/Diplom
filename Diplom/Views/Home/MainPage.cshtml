@{
    ViewData["Title"] = "Главная";
    Layout = "_Layout";
}
<link rel="stylesheet" href="~/css/MainPageStyle.css" />

<main class="home-page">

    <!-- HERO СЕКЦИЯ -->
    <section class="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-text animate-fadeInUp">
                <h1>Газовая служба <span class="accent">ЭкспрессГаз</span></h1>
                <p class="hero-subtitle">
                    Быстро, безопасно, надёжно. Аварийный выезд, ремонт, подключение — мы рядом 24/7.
                    Оставьте заявку, и ближайшая бригада прибудет в кратчайшие сроки.
                </p>
                <a asp-controller="Home" asp-action="Works" class="btn btn-hero">Отправить заявку</a>
            </div>
            <div class="hero-image animate-float">
                <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&h=400&fit=crop"
                     alt="Сотрудник газовой службы"
                     onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
            </div>
        </div>
    </section>

    <!-- ПРЕИМУЩЕСТВА -->
    <section class="features">
        <div class="container">
            <h2>Почему клиенты выбирают нас</h2>
            <div class="features-grid">
                <div class="feature-item animate-fadeInUp delay-1">
                    <div class="feature-icon">
                        <!-- Иконка: часы / 24/7 -->
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#f5a442" stroke-width="1.5">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                    </div>
                    <h3>Приедем за 30 минут</h3>
                    <p>Благодаря автоматическому распределению бригад ближайший мастер выезжает мгновенно — среднее время прибытия всего полчаса.</p>
                </div>
                <div class="feature-item animate-fadeInUp delay-2">
                    <div class="feature-icon">
                        <!-- Иконка: щит / безопасность -->
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#f5a442" stroke-width="1.5">
                            <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                    </div>
                    <h3>Гарантия безопасности</h3>
                    <p>Все специалисты сертифицированы, используют современное оборудование и строго соблюдают нормы газовой безопасности.</p>
                </div>
                <div class="feature-item animate-fadeInUp delay-3">
                    <div class="feature-icon">
                        <!-- Иконка: инструмент / wrench -->
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#f5a442" stroke-width="1.5">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.9 6.9a2.12 2.12 0 0 1-3-3l6.9-6.9a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                        </svg>
                    </div>
                    <h3>Любые виды работ</h3>
                    <p>От установки плиты до капитального ремонта газопровода — решим задачу любой сложности «под ключ».</p>
                </div>
            </div>
        </div>
    </section>

    <!-- КАК ЭТО РАБОТАЕТ -->
    <section class="how-it-works">
        <div class="container">
            <h2>Как вызвать мастера</h2>
            <div class="steps">
                <div class="step">
                    <div class="step-number">1</div>
                    <h4>Оформите заявку</h4>
                    <p>Заполните форму на сайте или позвоните нам — опишите проблему или нужную услугу.</p>
                </div>
                <div class="step">
                    <div class="step-number">2</div>
                    <h4>Система подберёт бригаду</h4>
                    <p>Умный алгоритм мгновенно назначит ближайшую свободную бригаду с нужным оборудованием.</p>
                </div>
                <div class="step">
                    <div class="step-number">3</div>
                    <h4>Мастер уже в пути</h4>
                    <p>Вы получаете уведомление о назначении, видите срок прибытия и можете отслеживать статус заявки.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ФОРМА ЗАЯВКИ -->
   

</main>

@section Scripts {
    <script>
        document.querySelector('a[href="#request"]').addEventListener('click', function(e) {
            e.preventDefault();
            document.querySelector('#request').scrollIntoView({ behavior: 'smooth' });
        });
    </script>
}