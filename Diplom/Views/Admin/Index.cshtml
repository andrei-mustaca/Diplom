@model Services.ViewModel.AdminPanelViewModel

@{
ViewData["Title"] = "Панель администратора";
Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/AdminStyle.css" />

<div class="admin-page">
    <div class="admin-hero">
        <h1 class="admin-title">⚙️ Панель администратора</h1>
        <p class="admin-subtitle">Управление пользователями, типами работ и отчетностью</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
    <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
    <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <div class="admin-tabs">
        <button class="tab-btn active" data-tab="users">👥 Пользователи</button>
        <button class="tab-btn" data-tab="worktypes">🛠️ Типы работ</button>
        <button class="tab-btn" data-tab="reports">📊 Отчеты</button>
    </div>

    <!-- ===== ПОЛЬЗОВАТЕЛИ ===== -->
    <div class="tab-content active" id="tab-users">
        <div class="tab-header-actions">
            <h2>👥 Пользователи</h2>
            <a asp-action="AddUser" class="btn-add">➕ Добавить пользователя</a>
        </div>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                <tr><th>ФИО</th><th>Email</th><th>Телефон</th><th>Роль</th><th>Действия</th></tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                <tr>
                    <td><strong>@user.FullName</strong></td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    <td><span class="role-badge @(user.Role.ToLower())">
                                @(user.Role == "Administrator" ? "👨‍💼 Админ" :
                            user.Role == "Dispatcher" ? "📋 Диспетчер" : "🔧 Рабочий")
                            </span></td>
                    <td>
                        <div class="action-buttons">
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn-edit">✏️</a>
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-delete" onclick="return confirm('Удалить?')">🗑️</button>
                            </form>
                        </div>
                    </td>
                </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ===== ТИПЫ РАБОТ ===== -->
    <div class="tab-content" id="tab-worktypes">
        <div class="tab-header-actions">
            <h2>🛠️ Типы работ</h2>
            <a asp-action="AddWorkType" class="btn-add">➕ Добавить тип работы</a>
        </div>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                <tr><th>Название</th><th>Описание</th><th>Время</th><th>Действия</th></tr>
                </thead>
                <tbody>
                @foreach (var wt in Model.WorkTypes)
                {
                <tr>
                    <td><strong>@wt.Name</strong></td>
                    <td>@wt.Description</td>
                    <td>⏱️ @wt.StandartDuration мин.</td>
                    <td>
                        <div class="action-buttons">
                            <a asp-action="EditWorkType" asp-route-id="@wt.Id" class="btn-edit">✏️</a>
                            <form asp-action="DeleteWorkType" asp-route-id="@wt.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-delete" onclick="return confirm('Удалить?')">🗑️</button>
                            </form>
                        </div>
                    </td>
                </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ===== ОТЧЕТЫ ===== -->
    <div class="tab-content" id="tab-reports">
        <div class="tab-header-actions">
            <h2>📊 Отчеты</h2>
            <form asp-action="ExportReport" method="post" class="export-form">
                @Html.AntiForgeryToken()
                <div class="export-fields">
                    <input type="date" name="fromDate" class="form-input" required />
                    <input type="date" name="toDate" class="form-input" required />
                    <button type="submit" class="btn-export">📥 Экспорт</button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                <tr><th>Дата</th><th>Клиент</th><th>Тип</th><th>Статус</th><th>Исполнитель</th><th>Время</th></tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Reports)
                {
                <tr>
                    <td>@r.RequestDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@r.PhoneClient</td>
                    <td>@r.WorkTypeName</td>
                    <td><span class="status-badge @(r.Status.ToLower())">@r.Status</span></td>
                    <td>@r.WorkerName</td>
                    <td>@r.Duration мин.</td>
                </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ===== ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК =====
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById('tab-' + this.dataset.tab).classList.add('active');
        });
    });
</script>
}